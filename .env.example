# ===========================================
# NAYAM (नयम्) — Environment Configuration
# ===========================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# ===========================================

# ── Application ──────────────────────────────────────────────
APP_NAME=NAYAM
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# ── Database ─────────────────────────────────────────────────
# SQLite (dev):  sqlite:///./nayam_dev.db
# Postgres (prod): postgresql://user:pass@localhost:5432/nayam_db
DATABASE_URL=sqlite:///./nayam_dev.db

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── AI / LLM (Phase 2) ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
AGENT_TIMEOUT_SECONDS=30
AGENT_MAX_CONTEXT_MESSAGES=20
ACTION_EXPIRY_HOURS=24

# ── Bhashini / Dhruva API (Indian language TTS + Translate) ──
BHASHINI_API_KEY=your_bhashini_api_key_here
BHASHINI_INFERENCE_URL=https://dhruva-api.bhashini.gov.in/services/inference/pipeline

# ── Predictive Governance (Phase 3) ─────────────────────────
RISK_COMPUTATION_INTERVAL_HOURS=6
ANOMALY_DEVIATION_THRESHOLD=2.0
PREDICTION_WINDOW_DAYS=7
RISK_MODEL_VERSION=v1.0

# ── Geo-Spatial / PostGIS (Phase 3) ─────────────────────────
POSTGIS_ENABLED=false
GEO_CLUSTER_RADIUS_METERS=500.0
HEATMAP_GRID_SIZE=50

# ── Zero-Knowledge Privacy (Phase 3) ────────────────────────
# Generate key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
PII_FIELDS=contact_number,email

# ── Autonomous Recommendations (Phase 3) ────────────────────
RECOMMENDATION_EXPIRY_HOURS=72
MAX_RECOMMENDATIONS_PER_WARD=10

# ── Observability (Phase 3) ─────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=365
ENABLE_AUDIT_LOGGING=true

# ── Offline-First & Edge Sync (Phase 4) ─────────────────────
OFFLINE_MODE_ENABLED=false
SYNC_INTERVAL_SECONDS=30
SYNC_MAX_RETRIES=3
SYNC_BATCH_SIZE=50
DEFAULT_NODE_ID=central

# ── Security Hardening (Phase 4) ────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
ENFORCE_HTTPS=false
TOKEN_ROTATION_ENABLED=false
TOKEN_ROTATION_DAYS=7

# ── Compliance (Phase 4) ────────────────────────────────────
COMPLIANCE_EXPORT_DIR=./exports
COMPLIANCE_RETENTION_DAYS=730

# ── Monitoring & Performance (Phase 4) ──────────────────────
ENABLE_PERFORMANCE_TRACKING=true
METRICS_RETENTION_DAYS=90
HEALTH_CHECK_INTERVAL_SECONDS=30
